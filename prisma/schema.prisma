generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Priority {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum WorkStatus {
  OPEN
  NEW
  TRIAGED
  APPROVED
  REJECTED
  PENDING_ASSIGNMENT
  ASSIGNED
  ACCEPTED
  IN_PROGRESS
  ON_HOLD
  COMPLETED
  PENDING_SUPERVISOR_REVIEW
  VERIFIED
  REOPENED
  CLOSED
}

enum AssetStatus {
  ACTIVE
  STANDBY
  DOWN
  RETIRED
}

enum RiskLevel {
  LOW
  MODERATE
  HIGH
  EXTREME
}

model User {
  id           String      @id @default(cuid())
  name         String
  email        String      @unique
  phone        String?
  role         String
  department   String
  supervisorEmail String?
  notifyWorkOrder Boolean  @default(false)
  notifyFacilityBooking Boolean @default(false)
  active       Boolean     @default(true)
  teamId       String?
  passwordHash String
  team         Team?       @relation(fields: [teamId], references: [id])
  workOrders   WorkOrder[]
  createdAt    DateTime    @default(now())
}

model Permission {
  id          String   @id @default(cuid())
  code        String   @unique
  name        String
  module      String
  description String
  roleLinks   RolePermission[]
}

model Role {
  id          String   @id @default(cuid())
  name        String   @unique
  description String
  standard    Boolean  @default(false)
  createdAt   DateTime @default(now())
}

model Department {
  id          String   @id @default(cuid())
  code        String   @unique
  name        String
  siteLocation String
  description String
  createdAt   DateTime @default(now())
}

model Employee {
  id              String   @id @default(cuid())
  name            String
  email           String   @unique
  companyId       String   @unique
  nationalityType String
  departmentCode  String
  siteLocation    String
  createdAt       DateTime @default(now())
}

model RolePermission {
  id           String     @id @default(cuid())
  role         String
  permissionId String
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@unique([role, permissionId])
}

model Team {
  id          String   @id @default(cuid())
  code        String   @unique
  name        String
  type        String
  supervisor  String
  phone       String
  email       String
  shift       String
  coverage    String
  users       User[]
  services    ServiceCatalog[]
  createdAt   DateTime @default(now())
}

model ServiceCatalog {
  id          String   @id @default(cuid())
  code        String   @unique
  name        String
  category    String
  type        String
  priority    Priority
  slaHours    Int
  teamId      String?
  description String
  active      Boolean  @default(true)
  team        Team?    @relation(fields: [teamId], references: [id])
  createdAt   DateTime @default(now())
}

model AssetCategory {
  id             String   @id @default(cuid())
  code           String   @unique
  name           String
  type           String
  defaultLifeYrs Int
  statutory      Boolean  @default(false)
  description    String
  createdAt      DateTime @default(now())
}

model Site {
  id        String     @id @default(cuid())
  name      String
  city      String
  country   String
  type      String
  areaSqm   Int
  buildings Building[]
  assets    Asset[]
}

model Building {
  id        String  @id @default(cuid())
  name      String
  code      String  @unique
  siteId    String
  floors    Int
  areaSqm   Int
  site      Site    @relation(fields: [siteId], references: [id], onDelete: Cascade)
  spaces    Space[]
  assets    Asset[]
}

model Space {
  id         String   @id @default(cuid())
  name       String
  floor      String
  type       String
  capacity   Int
  areaSqm    Int
  occupancy  Int
  buildingId String
  building   Building @relation(fields: [buildingId], references: [id], onDelete: Cascade)
}

model Asset {
  id              String       @id @default(cuid())
  tag             String       @unique
  name            String
  category        String
  system          String
  criticality     Priority
  status          AssetStatus  @default(ACTIVE)
  serialNumber    String?
  siteCode        String?
  zone            String?
  buildingCode    String?
  assetGroup      String?
  assetDescription String?
  additionalDescription String?
  parentAsset     String?
  departmentCode  String?
  remarks         String?
  manufacturer    String
  model           String
  installDate     DateTime
  replacementDate DateTime
  warrantyExpiry  DateTime?
  contractRef     String?
  documentationUrl String?
  purchaseCost    Decimal      @db.Decimal(12, 2)
  salvageValue    Decimal      @default(0) @db.Decimal(12, 2)
  depreciationRate Decimal     @default(10) @db.Decimal(5, 2)
  conditionScore  Int
  floor           String?
  room            String?
  qrCode          String?
  siteId          String
  buildingId      String?
  site            Site         @relation(fields: [siteId], references: [id], onDelete: Cascade)
  building        Building?    @relation(fields: [buildingId], references: [id])
  workOrders      WorkOrder[]
  meters          Meter[]
  history         AssetHistory[]
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt
}

model AssetHistory {
  id        String   @id @default(cuid())
  assetId   String
  eventType String
  title     String
  details   String
  actor     String
  asset     Asset    @relation(fields: [assetId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
}

model ServiceRequest {
  id          String     @id @default(cuid())
  ticketNo    String     @unique
  title       String
  category    String
  departmentCode String?
  serviceCode String?
  assignedTeamCode String?
  assignedSupervisorEmail String?
  requester   String
  channel     String
  priority    Priority
  status      WorkStatus @default(NEW)
  location    String
  attachmentUrls String?
  rejectionReason String?
  reviewedAt  DateTime?
  approvedAt  DateTime?
  slaHours    Int
  dueAt       DateTime
  description String
  workOrder   WorkOrder?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
}

model WorkOrder {
  id               String          @id @default(cuid())
  woNo             String          @unique
  title            String
  type             String
  assetType        String?
  departmentCode   String?
  serviceCode      String?
  assignedTeamCode String?
  jobPlanCode      String?
  responseAt       DateTime?
  resolutionAt     DateTime?
  finishedAt       DateTime?
  photoUrls        String?
  assetsUsed       String?
  inventoryUsed    String?
  supervisorRequest String?
  workNotes        String?
  materialRequest  String?
  rejectionReason  String?
  supervisorDecision String?
  verifiedAt       DateTime?
  priority         Priority
  status           WorkStatus      @default(NEW)
  assetId          String?
  requestId        String?         @unique
  assignedToId     String?
  plannedStart     DateTime
  dueAt            DateTime
  estimatedHours   Decimal         @db.Decimal(6, 2)
  actualHours      Decimal?        @db.Decimal(6, 2)
  cost             Decimal         @db.Decimal(12, 2)
  jobPlan          String
  safetyNotes      String
  asset            Asset?          @relation(fields: [assetId], references: [id])
  request          ServiceRequest? @relation(fields: [requestId], references: [id])
  assignedTo       User?           @relation(fields: [assignedToId], references: [id])
  inventoryIssues  InventoryIssue[]
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt
}

model Location {
  id           String   @id @default(cuid())
  code         String   @unique
  site         String
  zone         String
  building     String
  floor        String
  room         String
  type         String
  description  String
  active       Boolean  @default(true)
  createdAt    DateTime @default(now())
}

model JobPlan {
  id           String   @id @default(cuid())
  code         String   @unique
  name         String
  assetType    String
  departmentCode String?
  serviceCode  String?
  estimatedHours Decimal @db.Decimal(6, 2)
  priority     Priority
  steps        String
  safetyNotes  String
  active       Boolean  @default(true)
  createdAt    DateTime @default(now())
}

model PreventiveMaintenance {
  id           String   @id @default(cuid())
  code         String   @unique
  name         String
  assetTag     String
  frequency    String
  nextDue      DateTime
  durationHrs  Decimal  @db.Decimal(6, 2)
  checklist    String
  active       Boolean  @default(true)
}

model InventoryItem {
  id             String           @id @default(cuid())
  sku            String           @unique
  name           String
  category       String
  unit           String
  onHand         Int
  reorderPoint   Int
  unitCost       Decimal          @db.Decimal(10, 2)
  vendor         String
  location       String
  issues         InventoryIssue[]
}

model InventoryIssue {
  id        String        @id @default(cuid())
  itemId    String
  workId    String
  quantity  Int
  item      InventoryItem @relation(fields: [itemId], references: [id], onDelete: Cascade)
  workOrder WorkOrder     @relation(fields: [workId], references: [id], onDelete: Cascade)
  issuedAt  DateTime      @default(now())
}

model Vendor {
  id        String   @id @default(cuid())
  name      String
  category  String
  rating    Decimal  @db.Decimal(3, 2)
  contact   String
  email     String
  phone     String
  contracts Contract[]
}

model Contract {
  id          String   @id @default(cuid())
  title       String
  vendorId    String
  type        String
  startDate   DateTime
  endDate     DateTime
  value       Decimal  @db.Decimal(14, 2)
  slaTarget   String
  vendor      Vendor   @relation(fields: [vendorId], references: [id], onDelete: Cascade)
}

model Inspection {
  id          String    @id @default(cuid())
  code        String    @unique
  title       String
  area        String
  inspector   String
  risk        RiskLevel
  score       Int
  status      WorkStatus
  dueAt       DateTime
  findings    String
}

model HseIncident {
  id          String    @id @default(cuid())
  refNo       String    @unique
  title       String
  area        String
  severity    RiskLevel
  status      WorkStatus
  reportedAt  DateTime  @default(now())
  correctiveAction String
}

model Meter {
  id        String   @id @default(cuid())
  name      String
  type      String
  unit      String
  reading   Decimal  @db.Decimal(14, 2)
  assetId   String?
  asset     Asset?   @relation(fields: [assetId], references: [id])
  readAt    DateTime @default(now())
}

model IotAlert {
  id          String    @id @default(cuid())
  source      String
  assetTag    String
  severity    Priority
  message     String
  status      WorkStatus
  detectedAt  DateTime  @default(now())
}

model AuditLog {
  id        String   @id @default(cuid())
  actorId   String?
  actorName String
  role      String
  action    String
  entity    String
  entityId  String
  details   String?
  createdAt DateTime @default(now())
}
